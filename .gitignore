# ====================================
# LinkVault Root .gitignore
# ====================================

# Environment files
.env
.env.local
.env.development
.env.production
.env.test

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
render.log
vercel.log

# ====================================
# Backend (Python)
# ====================================
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/.Python
backend/env/
backend/venv/
backend/ENV/
backend/env.bak/
backend/venv.bak/
backend/pythonenv*
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/coverage.xml
backend/*.cover
backend/.hypothesis/
backend/.mypy_cache/
backend/.ruff_cache/
backend/.pytype/
backend/.DS_Store
backend/*.egg-info/
backend/instance/
backend/.webassets-cache
backend/.scrapy
backend/*.db
backend/*.sqlite3
backend/*.sqlite
backend/user_data/
backend/firebase-service-account.json

# ====================================
# Frontend
# ====================================
frontend/node_modules/
frontend/.pnp
frontend/.pnp.js
frontend/package-lock.json
frontend/yarn.lock
frontend/coverage/
frontend/.nyc_output/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/build/
frontend/dist/
frontend/.cache/
frontend/.vercel/
frontend/.vercel_output/
frontend/*.tsbuildinfo
frontend/.DS_Store
frontend/*.log

# ====================================
# Docker
# ====================================
*.pid
docker-compose.override.yml
.dockerignore
Dockerfile*
!Dockerfile
!Dockerfile.test
*.docker-cache

# ====================================
# Firebase
# ====================================
firebase-debug.log
firebase-debug.*.log
.firebase/
*.firebase
firebase-service-account.json
service-account.json
*-firebase-adminsdk-*.json

# ====================================
# OS Generated
# ====================================
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk